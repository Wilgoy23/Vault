{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vault",
  "version": "0.1.0",
  "identifier": "com.willg.vault",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
  {
    "label": "main",
    "title": "Vault",
    "width": 900,
    "height": 600,
    "minWidth": 700,
    "minHeight": 400,
    "center": true
  },
  {
    "label": "overlay",
    "title": "Vault — Quick Access",
    "width": 480,
    "height": 400,
    "decorations": false,
    "alwaysOnTop": true,
    "visible": false,
    "center": true,
    "skipTaskbar": true,
    "resizable": false,
    "shadow": true
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
