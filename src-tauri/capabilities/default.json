{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the app",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "dialog:allow-open",
